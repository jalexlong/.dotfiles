#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles"

cd "$DOTFILES_DIR"

case "${1:-status}" in
    status)
        git status
        ;;
    pull)
        git pull --ff-only
        ;;
    push)
        shift || true
        git add -A
        git commit -m"${*:-update dotfiles}"
        git push
        ;;
    restow)
        ./scripts/apply-profile.sh "${2:-chromebook}"
        ;;
    install)
        ./install.sh "${2:-chromebook}"
        ;;
    *)
        echo "Usage: dotfiles {status|pull|push|restow [profile]|install [profile]}"
        exit 1
        ;;
esac
